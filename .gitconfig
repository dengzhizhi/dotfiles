[core]
	excludesfile = /Users/zdeng/.gitignore_global
    pager = diff-so-fancy | less --tabs=4 -RFX
[diff]
    tool = nvimdiff
[difftool "nvimdiff"]
    cmd = vim -f -d \"$LOCAL\" \"$REMOTE\"

[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[merge]
    tool = nvimdiff
[mergetool "nvimdiff"]
    cmd = vim -d $LOCAL $BASE $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[mergetool "emacsdiff"]
    cmd = emacs -nw --eval \"(ediff-merge-files-with-ancestor \\\"$LOCAL\\\" \\\"$REMOTE\\\" \\\"$BASE\\\" nil \\\"$MERGED\\\")\"
[user]
	name = Zhizhi Deng
	email = zdeng@example.com
# [color]
#     ui = false
#     branch = false
#     diff = false
#     interactive = false
#     status = false
#     log = false

[alias]
    br = branch
    st = status
    stu = status -uno
    ci = commit --verbose
    co = checkout
    di = diff
    dc = diff --cached
    amend = commit --amend
    aa = add --all
    ff = merge --ff-only
    noff = merge --no-ff
    fa = fetch --all
    pom = push origin master
    ds = diff --stat=160,120
    dh1 = diff HEAD~1
    dh = diff --name-only HEAD~1
    dm = diff master@{u}...HEAD
    dmc = diff --cached master...HEAD

    # Divergence (commits we added and commits remote added)
    div = divergence

    # Goodness (summary of diff lines added/removed/total)
    gn = goodness
    gnc = goodness --cached

    # Add current branch name to clipboard (copy-branch)
    cbr = "! git name-rev --name-only HEAD | pbcopy"

    # Fancy logging.
    #   h = head
    #   hp = head with patch
    #   r = recent commits, only current branch
    #   ra = recent commits, all reachable refs
    #   l = all commits, only current branch
    #   la = all commits, all reachable refs
    #   b = all branches
    #   bs = all branches, sorted by last commit date
    head = !git r -1
    h = !git head
    hp = "!. ~/.githelpers && show_git_head"
    r = !GIT_NO_PAGER=1 git l -30
    ra = !git r --all
    l = "!. ~/.githelpers && pretty_git_log"
    la = !git l --all
    b = "!. ~/.githelpers && pretty_git_branch"
    bs = "!. ~/.githelpers && pretty_git_branch_sorted"
    sync = "! git checkout --quiet HEAD && git fetch origin develop:develop && git checkout --quiet -"

    # fzf enabled shortcuts
    cob = "! git checkout $(git branch | fzf)"
    corf = "! git fetch --all && git checkout $(git branch -r | fzf | awk '{ st = index($0, \"/\");print substr($0, st+1)}')"
    cor = "! git checkout $(git branch -r | fzf | awk '{ st = index($0, \"/\");print substr($0, st+1)}')"
    af = "! git add $(git ls-files -m | fzf)"
    df = "! git diff $(git ls-files -m | fzf)"
    dft = "! git difftool -y $(git ls-files -m | fzf)"
    rmf = "! rm $(git ls-files --others --exclude-standard | fzf)"
    usf = "! git checkout -- $(git ls-files -m | fzf)"
    diffdev="! git difftool -t vimdiff -y develop..HEAD $(git diff --name-only develop..HEAD | fzf)"

[init]
	templatedir = /Users/zdeng/.config/git/templates
[filter "pom-version"]
	clean = python /Users/zdeng/.config/git/pom_version_filter.py --action clean  --pom-file-path %f
	smudge = python /Users/zdeng/.config/git/pom_version_filter.py --action smudge --pom-file-path %f
[color]
	ui = true
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[pull]
	ff = only
